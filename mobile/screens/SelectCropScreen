import React, { useState, useEffect } from 'react';
import { View, Text, FlatList, TouchableOpacity, StyleSheet, Alert, ActivityIndicator } from 'react-native';
import { supabase } from '../lib/supabase';
import * as Location from 'expo-location';

export default function SelectCropScreen({ navigation }) {
  const [zones, setZones] = useState([]);
  const [selectedZone, setSelectedZone] = useState(null);
  const [cultures, setCultures] = useState([]);
  const [loading, setLoading] = useState(true);
  const [detectingLocation, setDetectingLocation] = useState(false);

  useEffect(() => {
    fetchZones();
    detectZone();
  }, []);

  const fetchZones = async () => {
    const { data, error } = await supabase.from('zones').select('*');
    if (error) console.error(error);
    else setZones(data);
  };

  const detectZone = async () => {
    setDetectingLocation(true);
    try {
      let { status } = await Location.requestForegroundPermissionsAsync();
      if (status !== 'granted') {
        Alert.alert('Permission refusée', 'Nous utilisons votre localisation pour adapter les conseils.');
        setDetectingLocation(false);
        return;
      }
      let location = await Location.getCurrentPositionAsync({});
      // Ici, il faudrait une correspondance coordonnées -> zone agro-écologique.
      // Pour simplifier, on laisse l'utilisateur choisir manuellement.
      // On peut aussi pré-définir des zones approximatives.
      Alert.alert('Géolocalisation', 'Position obtenue. Vous pouvez choisir votre zone manuellement.');
    } catch (error) {
      console.error(error);
    } finally {
      setDetectingLocation(false);
    }
  };

  const loadCultures = async (zone) => {
    setLoading(true);
    const { data, error } = await supabase
      .from('crops')
      .select('*')
      .contains('zones', [zone]); // les zones sont un array, on filtre
    if (error) console.error(error);
    else setCultures(data);
    setLoading(false);
  };

  const handleZoneSelect = (zone) => {
    setSelectedZone(zone);
    loadCultures(zone.name);
  };

  const handleCropSelect = (crop) => {
    navigation.navigate('SelectSymptoms', { cropId: crop.id, cropName: crop.name });
  };

  return (
    <View style={styles.container}>
      <Text style={styles.title}>Zone agro-écologique</Text>
      <FlatList
        horizontal
        data={zones}
        keyExtractor={(item) => item.id.toString()}
        renderItem={({ item }) => (
          <TouchableOpacity
            style={[styles.zoneCard, selectedZone?.id === item.id && styles.zoneSelected]}
            onPress={() => handleZoneSelect(item)}
          >
            <Text style={styles.zoneLabel}>{item.label_fr}</Text>
          </TouchableOpacity>
        )}
        contentContainerStyle={styles.zoneList}
      />

      {selectedZone && (
        <>
          <Text style={styles.subtitle}>Cultures recommandées pour {selectedZone.label_fr}</Text>
          {loading ? (
            <ActivityIndicator size="large" color="#2e7d32" />
          ) : (
            <FlatList
              data={cultures}
              keyExtractor={(item) => item.id.toString()}
              renderItem={({ item }) => (
                <TouchableOpacity style={styles.cropCard} onPress={() => handleCropSelect(item)}>
                  <Text style={styles.cropName}>{item.name}</Text>
                  <Text style={styles.cropDesc}>{item.description}</Text>
                </TouchableOpacity>
              )}
            />
          )}
        </>
      )}
    </View>
  );
}

const styles = StyleSheet.create({
  container: { flex: 1, padding: 20, backgroundColor: '#f5f5f5' },
  title: { fontSize: 20, fontWeight: 'bold', marginBottom: 15 },
  zoneList: { paddingVertical: 10 },
  zoneCard: { backgroundColor: '#fff', padding: 10, borderRadius: 8, marginRight: 10, borderWidth: 1, borderColor: '#ccc' },
  zoneSelected: { backgroundColor: '#2e7d32', borderColor: '#2e7d32' },
  zoneLabel: { fontSize: 14 },
  subtitle: { fontSize: 18, fontWeight: 'bold', marginVertical: 15 },
  cropCard: { backgroundColor: '#fff', padding: 15, borderRadius: 8, marginBottom: 10, elevation: 2 },
  cropName: { fontSize: 16, fontWeight: 'bold' },
  cropDesc: { fontSize: 12, color: '#555', marginTop: 5 },
});